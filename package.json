{
  "name": "blueprint-arch-mcp",
  "version": "0.2.0",
  "description": "Blueprint MCP: multi-language architectural memory and guardrails for AI coding agents",
  "keywords": ["mcp", "architecture", "cursor", "ai", "typescript", "python", "java", "spring"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vedv7/BLUEPRINT.MCP.git"
  },
  "bugs": {
    "url": "https://github.com/Vedv7/BLUEPRINT.MCP/issues"
  },
  "homepage": "https://github.com/Vedv7/BLUEPRINT.MCP#readme",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": ["dist", "bin", "python", "docs", "LICENSE", "README.md"],
  "prepublishOnly": "npm run build",
  "bin": {
    "blueprint": "./bin/blueprint.mjs"
  },
  "scripts": {
    "dev": "node --enable-source-maps dist/cli/index.js",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:mcp": "node --enable-source-maps dist/mcp/server.js",
    "scan": "node --enable-source-maps dist/cli/index.js scan",
    "report": "node --enable-source-maps dist/cli/index.js report",
    "blueprint:check": "node --enable-source-maps dist/cli/index.js check",
    "demo:magic": "cmd /c \"cd examples\\demo-repo && node ..\\..\\dist\\cli\\index.js scan && node ..\\..\\dist\\cli\\index.js verify formatMoney src/utils/paymentFormatter.ts utility_payment_formatter\"",
    "test": "vitest run",
    "test:all": "npm run typecheck && npm run build && npm test && npm run demo:magic",
    "validate:phase1": "npm run build && node scripts/phase1-validation.mjs",
    "validate:phase5": "npm run build && node scripts/phase5-validation.mjs",
    "dogfood": "npm run build && node scripts/dogfood-v0.2.mjs"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "commander": "^13.1.0",
    "minimatch": "^10.0.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ts-morph": "^26.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
